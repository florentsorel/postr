{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Europe/Paris",
  "schedule": ["after 7am and before 10am"],
  "addLabels": ["dependencies"],
  "semanticCommitType": "chore",
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "rebaseWhen": "behind-base-branch",
  "enabledManagers": ["custom.regex", "dockerfile", "github-actions", "gomod", "npm"],
  "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths", "npmDedupe"],
  "packageRules": [
    {
      "description": "Group all Dockerfile base image updates (multi-stage)",
      "matchManagers": ["dockerfile"],
      "groupName": "dockerfile",
      "automerge": false
    },
    {
      "description": "Auto-merge and group Go patch updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch"],
      "groupName": "go patch",
      "automerge": true
    },
    {
      "description": "Auto-merge Go minor updates (separate PRs)",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor"],
      "automerge": true
    },
    {
      "description": "Group all GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "automerge": false
    },
    {
      "description": "Auto-merge npm patch updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch"],
      "groupName": "npm patch",
      "automerge": true
    },
    {
      "description": "npm minor and major updates are separate PRs",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [".github\\/workflows\\/.*\\.yml"],
      "matchStrings": [
        "\\s*uses: (?<depName>.*?)-action@v\\d\\s*with:\\s*version:\\s*(?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["README\\.md"],
      "matchStrings": ["go-(?<currentValue>[\\d\\.]+)-00ADD8"],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version"
    }
  ]
}
