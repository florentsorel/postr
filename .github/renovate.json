{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Europe/Paris",
  "schedule": ["after 7am and before 10am"],
  "addLabels": ["dependencies"],
  "semanticCommitType": "chore",
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "rebaseWhen": "behind-base-branch",
  "enabledManagers": [
    "custom.regex",
    "dockerfile",
    "github-actions",
    "gomod",
    "npm"
  ],
  "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths", "npmDedupe"],
  "packageRules": [
    {
      "description": "Group all Dockerfile base image updates (multi-stage)",
      "matchManagers": ["dockerfile"],
      "groupName": "dockerfile",
      "automerge": false
    },
    {
      "description": "Group Go version updates across go.mod, Dockerfile and README into a single PR",
      "matchPackageNames": ["go", "golang"],
      "matchDatasources": ["golang-version", "docker"],
      "groupName": "go version",
      "automerge": false
    },
    {
      "description": "Auto-merge and group Go patch updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch"],
      "groupName": "go patch",
      "automerge": true
    },
    {
      "description": "Auto-merge Go minor updates (separate PRs)",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor"],
      "automerge": true
    },
    {
      "description": "Group all GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "automerge": false
    },
    {
      "description": "Auto-merge golangci-lint patch updates",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["golangci/golangci-lint-action"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Auto-merge npm patch updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch"],
      "groupName": "npm patch",
      "automerge": true
    },
    {
      "description": "Group npm minor updates into a single PR",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor"],
      "groupName": "npm minor",
      "automerge": false
    },
    {
      "description": "npm major updates are separate PRs",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/README\\.md/"],
      "matchStrings": ["go-(?<currentValue>[\\d\\.]+)-00ADD8"],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/go\\.mod/"],
      "matchStrings": ["\\ngo (?<currentValue>\\d+\\.\\d+\\.\\d+)\\n"],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version"
    }
  ]
}
